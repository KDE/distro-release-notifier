#: src/notifier.cpp:22
#, kde-format
msgid "Upgrade available"
msgstr "アップグレードがあります"

#: src/notifier.cpp:23
#, kde-format
msgctxt "For example, 'KDE neon 24.04 is available.'"
msgid "%1 %2 is available."
msgstr "%1 %2 にアップグレードできます"

#: src/notifier.cpp:25
#, kde-format
msgid ""
"\n"
"Your device will stop receiving updates and security fixes in 1 day — please "
"upgrade when possible."
msgid_plural ""
"\n"
"Your device will stop receiving updates and security fixes in %1 days — "
"please upgrade when possible."
msgstr[0] ""
"\n"
"お使いのデバイスは残り %1 日で更新とセキュリティの修正の対象外となります。都"
"合の良いときにアップグレードを行ってください。"

#: src/notifier.cpp:30
#, kde-format
msgid ""
"\n"
"Your device is no longer receiving updates or security fixes — please "
"upgrade now."
msgstr ""
"\n"
"お使いのデバイスは更新とセキュリティの修正の対象外となっています。いますぐ"
"アップグレードしてください。"

#: src/notifier.cpp:49
#, kde-format
msgctxt "@action:button"
msgid "Upgrade"
msgstr "アップグレード"

#: src/screensaverinhibitor.cpp:24
#, kde-format
msgctxt "Screensaver inhibition reason"
msgid "Upgrading Operating System"
msgstr "オペレーティングシステムをアップグレード中"

#: src/upgraderprocess.cpp:98
#, kde-format
msgctxt "@title/window upgrade failure dialog"
msgid "Upgrade Failed"
msgstr "アップグレードに失敗"

#: src/upgraderprocess.cpp:104
#, kde-format
msgctxt "@title title widget above process output"
msgid "Upgrade failed with the following output:"
msgstr "アップグレードに失敗しました。出力内容は以下のとおりです。"
